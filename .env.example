# Copy this file to .env and fill in your values. Never commit .env to git.

# Get a token at https://app.deriv.com/account/api-token
# Use a token created on your DEMO account (login ID starts with VRTC) while testing.
DERIV_API_TOKEN=

# 1089 is Deriv's shared demo app_id, fine for personal use.
DERIV_APP_ID=1089

DERIV_WS_ENDPOINT=wss://ws.derivws.com/websockets/v3
DERIV_IS_DEMO=true

# --- Risk limits enforced by risk_manager.py, in your account currency ---
MAX_STAKE_PER_TRADE=1.0
MAX_DAILY_LOSS=10.0
MAX_OPEN_CONTRACTS=1
MAX_TRADES_PER_DAY=20
COOLDOWN_SECONDS_AFTER_LOSS=30
